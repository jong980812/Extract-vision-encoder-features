{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "Test: Load SigLIP Model",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/test_load_model.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {
                "CUDA_VISIBLE_DEVICES": "0"
            },
            "args": []
        },
        {
            "name": "Extract: Video Features",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/extract_video_features.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {
                "CUDA_VISIBLE_DEVICES": "0"
            },
            "args": [
                "--encoder", "clip",
                // "--model_name_or_path", "google/siglip-so400m-patch14-384",
                "--model_name_or_path", "openai/clip-vit-large-patch14-336",
                "--json_path", "data_jsons/ssv2_VP_default.json",
                "--video_root_dir", "/local_datasets/vlm_direction",
                "--output_dir", "results/clip/ssv2_VP_default/10x10",
                "--num_frames", "8",
                "--batch_size", "8",
                "--num_workers", "4",
                "--spatial_pool_stride", "10",
                "--spatial_pool_mode", "bilinear",
                "--force_sample"
            ]
        },
        {
            "name": "Probe: Linear (mean)",
            "type": "debugpy",
            "request": "launch",
            "program": "linear_probe.py",
            "console": "integratedTerminal",
            "env": {
                "CUDA_VISIBLE_DEVICES": "0"
            },
            "args": [
                "--feature_dir", "results/siglip/E2E_VP_default/features",
                "--json_path", "data_jsons/E2E_VP_default.json",
                "--label_key", "answer_text",
                "--pool_mode", "mean",
                "--train_ratio", "0.8",
                "--epochs", "50",
                "--lr", "1e-3",
                "--batch_size", "64",
                "--seed", "42"
            ]
        },
        {
            "name": "Probe: Linear (concat)",
            "type": "debugpy",
            "request": "launch",
            "program": "linear_probe.py",
            "console": "integratedTerminal",
            "env": {
                "CUDA_VISIBLE_DEVICES": "0"
            },
            "args": [
                "--feature_dir", "results/siglip/E2E_real_VP_default/features",
                "--json_path", "data_jsons/E2E_real_VP_default.json",
                "--label_key", "answer_text",
                "--pool_mode", "concat_full",
                "--train_ratio", "0.8",
                "--epochs", "50",
                "--lr", "1e-3",
                "--batch_size", "64",
                "--seed", "42"
            ]
        }
    ]
}